<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
  <!-- HttpSecurity.build() forces throws Exception — Spring Security API constraint -->
  <Match>
    <Class name="com.example.gatewai.adapter.in.web.SecurityConfig"/>
