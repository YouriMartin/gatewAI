# Copy to .env and fill in. Docker Compose reads .env automatically.
# .env is git-ignored — never commit real secrets.
#
# LOCAL-FIRST: no API key is required. By default all three routing tiers run
# on the bundled Ollama, so the gateway works out of the box with this file
# untouched (or with no .env at all).

# Optional: Anthropic API key. Only needed if you point a model-registry tier
# at the 'anthropic' provider instance (see application.properties).
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI API key. Same opt-in mechanism as Anthropic.
# OPENAI_API_KEY=sk-...

# Optional: Ollama endpoint for the default local chat egress. Defaults to
# localhost for `./mvnw spring-boot:run`; docker-compose.yml overrides it to
# the bundled Ollama service.
# OLLAMA_BASE_URL=http://localhost:11434

# Admin API key seeded at startup (your Bearer token for /v1/admin/**).
# Pick any secret value; prefix with 'gw_' for consistency. If left blank, a
# random admin key is generated and printed once in the gateway logs.
GATEWAI_ADMIN_API_KEY=gw_change-me-to-a-long-random-secret

# Optional: PostgreSQL credentials (defaults match docker-compose.yml).
POSTGRES_DB=greenaiproxy
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev

# Optional: real-time carbon intensity (ElectricityMaps). Leave blank to use the
# static per-zone fallback values in application.properties.
# ELECTRICITY_MAPS_TOKEN=
