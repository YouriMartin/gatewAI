# Copy to .env and fill in. Docker Compose reads .env automatically.
# .env is git-ignored — never commit real secrets.

# Required: Anthropic API key for the primary (Claude) egress.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI API key. Only needed if you opt into the OpenAI egress by
# pointing a model-registry tier at a provider=openai model (see
# application.properties). Left blank, the OpenAI chat model stays dormant.
# OPENAI_API_KEY=sk-...

# Admin API key seeded at startup (your Bearer token for /v1/admin/**).
# Pick any secret value; prefix with 'gw_' for consistency. If left blank, a
# random admin key is generated and printed once in the gateway logs.
GATEWAI_ADMIN_API_KEY=gw_change-me-to-a-long-random-secret

# Optional: PostgreSQL credentials (defaults match docker-compose.yml).
POSTGRES_DB=greenaiproxy
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev

# Optional: real-time carbon intensity (ElectricityMaps). Leave blank to use the
# static per-zone fallback values in application.properties.
# ELECTRICITY_MAPS_TOKEN=
